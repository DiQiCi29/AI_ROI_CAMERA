# ============================================
# AI_ROI_CAMERA - Environment Configuration
# ============================================
# Copy this file to .env and update values

# Application Settings
APP_NAME=AI_ROI_CAMERA
APP_VERSION=1.0.0
DEBUG=True

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=ai_roi_camera

# ============================================
# Security Configuration
# ============================================
# Generate a strong secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secure-secret-key-here-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# Firebase Configuration
# ============================================
# Path to Firebase Admin SDK credentials JSON file
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json

# ============================================
# Camera/Stream Configuration
# ============================================
# MediaMTX RTSP server settings
MEDIAMTX_HOST=localhost
MEDIAMTX_PORT=9997

# Default RTSP camera URL (for single camera setup)
# Individual cameras can be configured in database
DEFAULT_RTSP_URL=rtsp://username:password@192.168.0.3:554/onvif1

# ============================================
# Logging Configuration (Optional)
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ============================================
# Email Notifications (Optional)
# ============================================
# For sending email alerts (future feature)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ALERT_EMAIL_TO=recipient@example.com

# ============================================
# AI Model Configuration
# ============================================
# YOLOv8 model size: nano, small, medium, large, xlarge
YOLO_MODEL_SIZE=small
# Path to YOLOv8 model weights
YOLO_MODEL_PATH=./app/ai/yolov8s.pt
# Confidence threshold for detection (0-1)
YOLO_CONFIDENCE_THRESHOLD=0.5
# NMS (Non-Maximum Suppression) threshold (0-1)
YOLO_NMS_THRESHOLD=0.45
